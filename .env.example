# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Prisma)
# Transaction pooler URL — used by app at runtime (port 6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct URL — used ONLY by prisma migrate (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
